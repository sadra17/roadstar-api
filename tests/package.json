  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator":  "^7.0.1",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.2",
    "luxon":              "^3.4.4",
    "mongoose":           "^8.3.1",
    "morgan":             "^1.10.0",
    "socket.io":          "^4.7.5",
    "twilio":             "^5.0.0"
  },
  "devDependencies": {
    "jest":                 "^29.7.0",
    "mongodb-memory-server":"^10.1.2",
    "nodemon":              "^3.1.0",
    "supertest":            "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/tests/**/*.test.js"],
    "testTimeout":     30000
  }
